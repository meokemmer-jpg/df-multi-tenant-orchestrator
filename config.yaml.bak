df_id: df-multi-tenant-orchestrator
df_name: Multi-Hotel-Tenant-Orchestrator
welle_introduced: welle-47
type: foundation-df
crux-mk: true
k0_touch: false
q0_touch: false
phronesis_required: false

# === Default-Action (per ausreden-schutz.md Schicht 2, Welle-47 Migration Batch-2) ===
default_action:
  description: "Multi-Hotel-Tenant-Boundary-Orchestration: TenantContext-Isolation pro Hotel-ID, Parallel-Dispatch ueber N Hotels, Cross-Tenant-Read-Prevention via Negative-Tests"
  rho_per_run_eur: 60
  rho_validation_source: unvalidated
  block_gates:
    - gate_id: K11
      block_reason: "Cascade-Containment Pflicht: Hotel-Failure darf nicht andere Hotels betreffen (failure_blast_radius=1)"
      false_block_cost_eur: 40
      legitimate_block_condition: "Cross-Tenant-Leak detected ODER DLQ-Cross-Contamination"
    - gate_id: K13_PAV
      block_reason: "Pre-Action-Verification Pflicht: env_tag + mount_point + blast_radius pro Tenant-Operation"
      false_block_cost_eur: 30
      legitimate_block_condition: "env_tag=prod ohne PHRONESIS_TICKET ODER mount_point ist shared/external Resource"
  graceful_degradation_path: "Read-only-Tenant-List + Mock-Dispatch (kein Real-Cross-Tenant-State-Mutation)"

# K11 Cascade-Containment
cascade_isolation: hard
failure_blast_radius: 1

# K12 Distillation-Resistenz (W49-D upgrade)
output_feeds_into_training: false
provenance_required_in_output: true
non_llm_validation_layer: true
envelope_schema: full_provenance_envelope_v1.0   # W49-D K12
hmac_secret_env_var: DF_MULTI_TENANT_HMAC_SECRET
envelope_ttl_seconds: 86400

# K13 Independent-Ground-Truth (W49-D upgrade: rfc3161)
external_anchor_type: rfc3161                    # W49-D K13 (was: drive_filesystem)
external_anchor_provider: freetsa
external_anchor_validation_frequency: per_run
pre_action_domain_check: true
pre_action_backup_check: true
pre_action_blast_radius_check: true

# K14 Human-Override-Decay
override_complexity: single_command
override_documentation_freshness_days: 30
martin_review_cadence: weekly
bus_factor_handover_drilled: false

# K15 Entropy-Budget
entropy_added_loc_estimate: 800
entropy_added_concepts:
  - HotelRegistry
  - ParallelDispatcher
  - TenantIsolationEnforcer
entropy_justified_by_rho: 0.05  # EUR/J/LOC
entropy_subtractive_potential: true

# K16 Concurrent-Spawn-Mutex (W49-D AtomicLock-reference)
concurrent_spawn_protection: both
lock_dir: /tmp/df-multi-tenant-orchestrator.lock
lock_stale_age_h: 6
engine_pgrep_check: true
lock_release_on: EXIT_INT_TERM
lock_implementation: atomic_lock                 # W49-D K16

# Lose-Coupling LC1-LC5
lose_coupling:
  LC1_graceful_degradation:
    degradation_modes:
      - full
      - degraded_no_real_hotels
      - sandbox_mock
    degradation_test_required: true
  LC2_direct_mode:
    direct_mode_available: true
    direct_mode_capability: 0.7
    direct_mode_trigger: "real-hotels unreachable >30s"
  LC3_circuit_breaker:
    circuit_breaker_timeout_s: 30
    circuit_breaker_open_threshold: 3
    circuit_breaker_half_open_test_interval_s: 300
  LC4_failure_isolation:
    state_externalization: true
    idempotent_operations: true
    dependency_dlq_separate: true
  LC5_health_check:
    health_check_dependencies: []
    health_check_degraded_score: 0.7
    health_check_endpoint_or_file: state/health.json

# ENV-Var-Gated-Real-Integration-Default
env_vars:
  DF_MULTI_TENANT_REAL_HOTELS_ENABLED: false
  PHRONESIS_TICKET: ""

# Mock-Hotels (Sandbox-Default)
mock_hotels:
  - tenant_id: hildesheim
    name: HeyLou Hildesheim
    region: DE
  - tenant_id: cape-coral
    name: HeyLou Cape Coral
    region: US
  - tenant_id: munich
    name: HeyLou Munich
    region: DE
  - tenant_id: mock-4
    name: HeyLou Mock-4
    region: DE
  - tenant_id: mock-5
    name: HeyLou Mock-5
    region: AT

# Scheduling
schedule:
  type: launchagent
  cadence: daily
  hour: 2
  minute: 0
